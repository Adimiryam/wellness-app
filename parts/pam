        {/* Step 3: Health Conditions */}
        {step === 3 && (
          <div>
            <div style={{ fontSize: 20, fontWeight: 700, color: "#1e293b", marginBottom: 4, textAlign: "right" }}>
              🏥 מצב בריאותי
            </div>
            <div style={{ fontSize: 13, color: "#64748b", marginBottom: 20, textAlign: "right" }}>
              יש לך מחלות, מיחושים או כאבים כרוניים? (ניתן לבחור כמה)
            </div>

            <div style={{ display: "flex", flexWrap: "wrap", gap: 8, marginBottom: 16, justifyContent: "flex-end" }}>
              {HEALTH_CONDITIONS.map(c => {
                const isSelected = conditions.includes(c.id);
                return (
                  <button key={c.id} onClick={() => toggleCondition(c.id)}
                    style={{
                      padding: "10px 14px", borderRadius: 20, border: "2px solid",
                      borderColor: isSelected ? "#6366f1" : "#e2e8f0",
                      background: isSelected ? "#eef2ff" : "#fff",
                      color: isSelected ? "#6366f1" : "#64748b",
                      cursor: "pointer", fontSize: 13, fontWeight: 500,
                      display: "flex", alignItems: "center", gap: 6, transition: "all 0.2s"
                    }}>
                    <span>{c.label}</span>
                    <span>{c.icon}</span>
                  </button>
                );
              })}
            </div>

            {!conditions.includes("none") && conditions.length > 0 && (
              <div style={cardStyle}>
                <label style={{ display: "block", fontSize: 14, fontWeight: 600, color: "#475569", marginBottom: 8, textAlign: "right" }}>
                  פרטים נוספים על המצב הבריאותי (אופציונלי)
                </label>
                <textarea placeholder="למשל: יש לי מיגרנות פעם בשבוע, כאבי גב תחתון כרוניים..."
                  value={conditionNotes} onChange={e => setConditionNotes(e.target.value)}
                  rows={3} style={{ ...inputStyle, resize: "vertical" }} />
              </div>
            )}

            <div style={cardStyle}>
              <label style={{ display: "block", fontSize: 14, fontWeight: 600, color: "#475569", marginBottom: 8, textAlign: "right" }}>
                אלרגיות ורגישויות למזון (אופציונלי)
              </label>
              <input type="text" placeholder="למשל: בוטנים, סויה, גלוטן..."
                value={allergies} onChange={e => setAllergies(e.target.value)} style={inputStyle} />
            </div>

            <div style={cardStyle}>
              <label style={{ display: "block", fontSize: 14, fontWeight: 600, color: "#475569", marginBottom: 8, textAlign: "right" }}>
                כאבים או מיחושים שחוזרים (אופציונלי)
              </label>
              <input type="text" placeholder="למשל: כאבי בטן, פריחה, כאב ראש..."
                value={painAreas} onChange={e => setPainAreas(e.target.value)} style={inputStyle} />
            </div>
          </div>
        )}

        {/* Step 4: Medications & Supplements */}
        {step === 4 && (
          <div>
            <div style={{ fontSize: 20, fontWeight: 700, color: "#1e293b", marginBottom: 4, textAlign: "right" }}>
              💊 תרופות ותוספים
            </div>
            <div style={{ fontSize: 13, color: "#64748b", marginBottom: 20, textAlign: "right" }}>
              איזה תרופות ותוספי תזונה את/ה לוקח/ת?
            </div>

            <div style={cardStyle}>
              <label style={{ display: "block", fontSize: 14, fontWeight: 600, color: "#475569", marginBottom: 8, textAlign: "right" }}>
                תרופות קבועות (אופציונלי)
              </label>
              <textarea placeholder="למשל: אלטרוקסין, ונטולין..."
                value={currentMeds} onChange={e => setCurrentMeds(e.target.value)}
                rows={2} style={{ ...inputStyle, resize: "vertical" }} />
            </div>

            <div style={cardStyle}>
              <div style={{ fontSize: 14, fontWeight: 600, color: "#475569", marginBottom: 12, textAlign: "right" }}>
                ויטמינים ותוספי תזונה שאת/ה לוקח/ת:
              </div>
              <div style={{ display: "flex", flexWrap: "wrap", gap: 8, marginBottom: 12, justifyContent: "flex-end" }}>
                {SUPPLEMENTS.map(sup => {
                  const taken = currentSupplements.includes(sup);
                  return (
                    <button key={sup} onClick={() => toggleSupplement(sup)}
                      style={{
                        padding: "8px 14px", borderRadius: 20, border: "2px solid",
                        borderColor: taken ? "#22c55e" : "#e2e8f0",
                        background: taken ? "#f0fdf4" : "#fff",
                        color: taken ? "#166534" : "#64748b",
                        cursor: "pointer", fontSize: 13, fontWeight: 500,
                        display: "flex", alignItems: "center", gap: 4
                      }}>
                      <span>{sup}</span>
                      {taken && <Check size={14} />}
                    </button>
                  );
                })}
              </div>
              <div style={{ display: "flex", gap: 8, direction: "rtl" }}>
                <input type="text" placeholder="תוסף אחר..." value={customSupplement} onChange={e => setCustomSupplement(e.target.value)}
                  onKeyDown={e => { if (e.key === "Enter" && customSupplement.trim()) { toggleSupplement(customSupplement.trim()); setCustomSupplement(""); }}}
                  style={{ ...inputStyle, flex: 1 }} />
                <button onClick={() => { if (customSupplement.trim()) { toggleSupplement(customSupplement.trim()); setCustomSupplement(""); }}}
                  style={{ padding: "10px 16px", borderRadius: 10, border: "none", background: "#6366f1", color: "#fff", cursor: "pointer", fontWeight: 600 }}>
                  <Plus size={18} />
                </button>
              </div>
            </div>
          </div>
        )}

        {/* Step 5: What to Track */}
        {step === 5 && (
          <div>
            <div style={{ fontSize: 20, fontWeight: 700, color: "#1e293b", marginBottom: 4, textAlign: "right" }}>
              📊 מה תרצה/י לעקוב?
            </div>
            <div style={{ fontSize: 13, color: "#64748b", marginBottom: 20, textAlign: "right" }}>
              בחר/י את הנתונים שחשוב לך לעקוב אחריהם כל יום
            </div>

            <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 20 }}>
              {TRACKING_OPTIONS.map(opt => {
                const isSelected = trackingChoices.includes(opt.id);
                return (
                  <button key={opt.id} onClick={() => toggleTracking(opt.id)}
                    style={{
                      padding: 14, borderRadius: 14, border: "2px solid",
                      borderColor: isSelected ? opt.color : "#e2e8f0",
                      background: isSelected ? `${opt.color}10` : "#fff",
                      cursor: "pointer", textAlign: "center",
                      boxShadow: isSelected ? `0 3px 10px ${opt.color}20` : "none",
                      transition: "all 0.2s"
                    }}>
                    <div style={{ fontSize: 24, marginBottom: 4 }}>{opt.icon}</div>
                    <div style={{ fontSize: 13, fontWeight: 600, color: isSelected ? opt.color : "#475569" }}>{opt.label}</div>
                    {isSelected && <Check size={16} color={opt.color} style={{ marginTop: 4 }} />}
                  </button>
                );
              })}
            </div>

            <div style={{ background: "#f0f9ff", borderRadius: 12, padding: 16 }}>
              <div style={{ fontSize: 14, fontWeight: 700, color: "#0369a1", marginBottom: 6, textAlign: "right" }}>
                💡 אפשר לשנות בכל עת
              </div>
              <div style={{ fontSize: 13, color: "#0c4a6e", textAlign: "right" }}>
                תמיד אפשר להוסיף או להסיר נתונים למעקב מההגדרות. ככל שתזין/י יותר נתונים, התובנות יהיו מדויקות יותר!
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Bottom Navigation */}
      <div style={{ position: "fixed", bottom: 0, left: "50%", transform: "translateX(-50%)", width: "100%", maxWidth: 480, background: "#fff", borderTop: "1px solid #e2e8f0", padding: "12px 16px", display: "flex", gap: 10, boxSizing: "border-box", zIndex: 100 }}>
        {step > 0 && (
          <button onClick={() => setStep(step - 1)}
            style={{ flex: 1, padding: 14, borderRadius: 12, border: "2px solid #e2e8f0", background: "#fff", color: "#64748b", fontSize: 15, fontWeight: 600, cursor: "pointer" }}>
            → חזרה
          </button>
        )}
        <button onClick={() => { if (step < totalSteps - 1) setStep(step + 1); else handleComplete(); }}
          disabled={!canProceed()}
          style={{
            flex: 2, padding: 14, borderRadius: 12, border: "none",
            background: canProceed() ? "linear-gradient(135deg, #6366f1, #8b5cf6)" : "#e2e8f0",
            color: canProceed() ? "#fff" : "#94a3b8",
            fontSize: 16, fontWeight: 700, cursor: canProceed() ? "pointer" : "not-allowed",
            transition: "all 0.2s"
          }}>
          {step < totalSteps - 1 ? "← המשך" : "🚀 בואו נתחיל!"}
        </button>
      </div>
    </div>
  );
};

