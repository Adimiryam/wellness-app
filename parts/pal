            .sort((a, b) => b.cycleCount - a.cycleCount);

          // Check if we're currently in PMS window
          const now = new Date();
          const lastPeriod = periodStarts.map(d => new Date(d)).sort((a, b) => b - a)[0];
          const cycleLen = 28;
          let daysUntilNext = null;
          if (lastPeriod) {
            const nextEst = new Date(lastPeriod);
            nextEst.setDate(nextEst.getDate() + cycleLen);
            daysUntilNext = Math.round((nextEst - now) / 86400000);
          }
          const inPmsNow = daysUntilNext !== null && daysUntilNext > 0 && daysUntilNext <= PMS_WINDOW_DAYS;

          return (
            <div style={{ background: "#fff", borderRadius: 16, padding: 16, marginBottom: 16, boxShadow: "0 2px 8px rgba(0,0,0,0.06)", border: "2px solid #ec489933" }}>
