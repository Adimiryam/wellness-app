            <div style={{ fontSize: 11, color: totalChange <= 0 ? "#16a34a" : "#dc2626" }}>
              {pctChange > 0 ? "+" : ""}{pctChange.toFixed(1)}% ממשקל הגוף
            </div>
          </div>
          <div style={{ background: "#f0f9ff", borderRadius: 12, padding: 12, textAlign: "center" }}>
