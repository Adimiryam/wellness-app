      const daysLeft = dietProject.deadline ? Math.max(0, Math.ceil((new Date(dietProject.deadline) - now) / 86400000)) : null;
      return { lost: lost.toFixed(1), goal: goal.toFixed(1), pct: pct.toFixed(0), daysLeft };
