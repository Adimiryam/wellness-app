            <div style={{ fontSize: 20, fontWeight: 700, color: "#0369a1" }}>{lowestW}-{highestW}</div>
            <div style={{ fontSize: 11, color: "#64748b" }}>ק"ג</div>
          </div>
          <div style={{ background: "#faf5ff", borderRadius: 12, padding: 12, textAlign: "center" }}>
            <div style={{ fontSize: 11, color: "#64748b" }}>ירידה יומית ממוצעת</div>
