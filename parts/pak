      if (!newWeightValue || isNaN(parseFloat(newWeightValue))) return;
      const entry = { date: newWeightDate, weight: parseFloat(parseFloat(newWeightValue).toFixed(1)) };
      const existing = weightHistory.findIndex(e => e.date === newWeightDate);
      if (existing >= 0) {
        const updated = [...weightHistory];
        updated[existing] = entry;
        setWeightHistory(updated);
      } else {
        setWeightHistory([...weightHistory, entry]);
      }
      setNewWeightValue("");
      setShowAddWeightForm(false);
    };

    const createDietProject = () => {
