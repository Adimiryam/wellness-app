                const step = Math.max(1, Math.floor(points.length / 5));
                return i === 0 || i === points.length - 1 || i % step === 0;
              }).map((p, i) => (
                <text key={i} x={p.x} y={graphH - 4} textAnchor="middle" fontSize="8" fill="#94a3b8">
                  {p.date.slice(5)}
