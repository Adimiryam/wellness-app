              <div style={{ position: "relative", height: 4, background: "#f1f5f9", borderRadius: 2 }}>
                <div style={{ position: "absolute", top: -3, width: 10, height: 10, borderRadius: 5, background: "#1e293b", left: ((dayInCycle / avgCycle) * 100) + "%", transform: "translateX(-50%)" }} />
              </div>
            )}
          </div>
        )}
      </div>
    );
  };

  const renderWeight = () => {
    const periods = [
      { id: "day", label: "24 שעות" },
      { id: "week", label: "שבוע" },
      { id: "2weeks", label: "שבועיים" },
      { id: "month", label: "חודש" },
      { id: "3months", label: "3 חודשים" },
    ];

    const now = new Date();
    const periodDays = { day: 1, week: 7, "2weeks": 14, month: 30, "3months": 90 };
    const days = periodDays[weightTimePeriod] || 30;
    const cutoff = new Date(now);
    cutoff.setDate(cutoff.getDate() - days);
    const cutoffStr = cutoff.toISOString().split("T")[0];

    const filtered = weightHistory.filter(e => e.date >= cutoffStr).sort((a, b) => a.date.localeCompare(b.date));

    // Stats
    const startW = filtered.length > 0 ? filtered[0].weight : null;
    const endW = filtered.length > 0 ? filtered[filtered.length - 1].weight : null;
    const totalChange = startW && endW ? (endW - startW) : 0;
    const pctChange = startW ? ((totalChange / startW) * 100) : 0;
    const dailyRate = days > 0 ? (totalChange / days) : 0;
    const weeklyRate = dailyRate * 7;
    const monthlyRate = dailyRate * 30;
    const allSorted = [...weightHistory].sort((a, b) => a.date.localeCompare(b.date));
    const currentW = allSorted.length > 0 ? allSorted[allSorted.length - 1].weight : null;
    const highestW = filtered.length > 0 ? Math.max(...filtered.map(e => e.weight)) : 0;
    const lowestW = filtered.length > 0 ? Math.min(...filtered.map(e => e.weight)) : 0;

    // SVG Graph
    const graphW = 340;
    const graphH = 180;
    const padL = 40;
    const padR = 10;
    const padT = 15;
    const padB = 30;
    const innerW = graphW - padL - padR;
    const innerH = graphH - padT - padB;

    const minW = filtered.length > 0 ? Math.floor(Math.min(...filtered.map(e => e.weight)) - 1) : 60;
    const maxW = filtered.length > 0 ? Math.ceil(Math.max(...filtered.map(e => e.weight)) + 1) : 80;
    const wRange = maxW - minW || 1;

    const points = filtered.map((e, i) => {
      const x = padL + (filtered.length > 1 ? (i / (filtered.length - 1)) * innerW : innerW / 2);
      const y = padT + innerH - ((e.weight - minW) / wRange) * innerH;
      return { x, y, ...e };
    });

