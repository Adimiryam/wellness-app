        </div>

        {/* Current Weight Display */}
        {currentW && (
          <div style={{ background: "linear-gradient(135deg, #6366f1, #8b5cf6)", borderRadius: 16, padding: 18, marginBottom: 14, color: "#fff", textAlign: "center" }}>
            <div style={{ fontSize: 13, opacity: 0.85 }}>משקל נוכחי</div>
            <div style={{ fontSize: 36, fontWeight: 800 }}>{currentW} <span style={{ fontSize: 16 }}>ק"ג</span></div>
            {dietProject && (
              <div style={{ fontSize: 12, opacity: 0.8, marginTop: 4 }}>יעד: {dietProject.targetWeight} ק"ג</div>
            )}
          </div>
        )}

        {/* BMI Card */}
        <BmiCard profile={userProfile} morningWeight={currentW} />

        {/* Time Period Buttons */}
        <div style={{ display: "flex", gap: 6, marginBottom: 14, flexWrap: "wrap", justifyContent: "center" }}>
          {periods.map(p => (
            <button key={p.id} onClick={() => setWeightTimePeriod(p.id)} style={{
              padding: "6px 12px", borderRadius: 20, border: "none", fontSize: 12, fontWeight: 600, cursor: "pointer",
              background: weightTimePeriod === p.id ? "#6366f1" : "#f1f5f9",
              color: weightTimePeriod === p.id ? "#fff" : "#64748b",
            }}>{p.label}</button>
          ))}
        </div>

        {/* SVG Weight Graph */}
        <div style={{ background: "#fff", borderRadius: 16, padding: 14, marginBottom: 14, boxShadow: "0 1px 4px rgba(0,0,0,0.06)" }}>
          <div style={{ fontSize: 14, fontWeight: 600, color: "#374151", marginBottom: 8, textAlign: "right" }}>
            גרף משקל - {periods.find(p => p.id === weightTimePeriod)?.label}
          </div>
          {filtered.length > 1 ? (
            <svg width={graphW} height={graphH} viewBox={"0 0 " + graphW + " " + graphH} style={{ width: "100%", height: "auto" }}>
              <defs>
                <linearGradient id="weightGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stopColor="#6366f1" stopOpacity="0.3" />
                  <stop offset="100%" stopColor="#6366f1" stopOpacity="0.02" />
                </linearGradient>
              </defs>
              {/* Grid lines */}
              {[0, 0.25, 0.5, 0.75, 1].map((frac, i) => {
                const yPos = padT + innerH * (1 - frac);
                const val = (minW + wRange * frac).toFixed(1);
                return (
                  <g key={i}>
                    <line x1={padL} y1={yPos} x2={graphW - padR} y2={yPos} stroke="#e5e7eb" strokeWidth="1" />
                    <text x={padL - 4} y={yPos + 4} textAnchor="end" fontSize="9" fill="#94a3b8">{val}</text>
                  </g>
                );
              })}
              {/* Area fill */}
              <polygon points={padL + "," + (padT + innerH) + " " + polyline + " " + (padL + innerW) + "," + (padT + innerH)} fill="url(#weightGrad)" />
              {/* Line */}
              <polyline points={polyline} fill="none" stroke="#6366f1" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round" />
              {/* Diet project target line */}
              {dietProject && dietProject.targetWeight >= minW && dietProject.targetWeight <= maxW && (
                <line x1={padL} y1={padT + innerH - ((dietProject.targetWeight - minW) / wRange) * innerH}
                  x2={graphW - padR} y2={padT + innerH - ((dietProject.targetWeight - minW) / wRange) * innerH}
                  stroke="#ef4444" strokeWidth="1.5" strokeDasharray="6,4" />
              )}
              {/* Data points */}
              {points.map((p, i) => (
                <circle key={i} cx={p.x} cy={p.y} r="3" fill="#6366f1" stroke="#fff" strokeWidth="1.5" />
