                  </div>
                  <div>
                    <div style={{ fontSize: 16, fontWeight: 700, color: "#f59e0b" }}>{dpProgress.daysLeft !== null ? dpProgress.daysLeft : "--"}</div>
                    <div style={{ fontSize: 10, color: "#64748b" }}>ימים נותרו</div>
                  </div>
                </div>
              </div>
            )}
          </div>
        ) : (
          <div>
            {showDietProjectForm ? (
              <div style={{ background: "#fff", borderRadius: 16, padding: 14, marginBottom: 14, boxShadow: "0 1px 4px rgba(0,0,0,0.06)" }}>
                <div style={{ fontSize: 14, fontWeight: 600, color: "#1e293b", marginBottom: 10, textAlign: "right" }}>
                  יצירת פרויקט דיאטה חדש
                </div>
                <input value={dietProjectName} onChange={e => setDietProjectName(e.target.value)}
                  placeholder="שם הפרויקט (למשל: דיאטת קיץ)"
                  style={{ width: "100%", padding: 10, borderRadius: 10, border: "1px solid #e2e8f0", marginBottom: 8, fontSize: 14, textAlign: "right", boxSizing: "border-box" }} />
                <input value={dietProjectTarget} onChange={e => setDietProjectTarget(e.target.value)}
                  placeholder="משקל יעד (ק״ג)" type="number" step="0.1"
                  style={{ width: "100%", padding: 10, borderRadius: 10, border: "1px solid #e2e8f0", marginBottom: 8, fontSize: 14, textAlign: "right", boxSizing: "border-box" }} />
                <input value={dietProjectDeadline} onChange={e => setDietProjectDeadline(e.target.value)}
                  type="date" placeholder="תאריך יעד (אופציונלי)"
                  style={{ width: "100%", padding: 10, borderRadius: 10, border: "1px solid #e2e8f0", marginBottom: 10, fontSize: 14, textAlign: "r