      setShowDietProjectForm(false);
      setDietProjectName("");
      setDietProjectTarget("");
      setDietProjectDeadline("");
    };

    return (
      <div>
        <div style={{ fontSize: 20, fontWeight: 700, color: "#1e293b", marginBottom: 10, textAlign: "right" }}>
          <Weight size={20} style={{ verticalAlign: "middle", marginLeft: 6 }} />
