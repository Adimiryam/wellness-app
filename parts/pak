                  <span>התחלה: {dietProject.startWeight} ק"ג</span>
                  <span>יעד: {dietProject.targetWeight} ק"ג</span>
                </div>
                <div style={{ background: "#e5e7eb", borderRadius: 8, height: 14, overflow: "hidden", marginBottom: 8 }}>
                  <div style={{
                    width: dpProgress.pct + "%", height: "100%", borderRadius: 8,
                    background: "linear-gradient(90deg, #6366f1, #8b5cf6)",
                    transition: "width 0.5s ease",
                  }} />
                </div>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: 6, textAlign: "center" }}>
                  <div>
                    <div style={{ fontSize: 16, fontWeight: 700, color: "#6366f1" }}>{dpProgress.pct}%</div>
                    <div style={{ fontSize: 10, color: "#64748b" }}>הושלם</div>
