          <div style={{ background: "#fffbeb", borderRadius: 12, padding: 12, textAlign: "center" }}>
            <div style={{ fontSize: 11, color: "#64748b" }}>ירידה חודשית ממוצעת</div>
            <div style={{ fontSize: 18, fontWeight: 700, color: "#d97706" }}>{Math.abs(monthlyRate).toFixed(1)} ק"ג</div>
          </div>
          <div style={{ background: "#f0fdf4", borderRadius: 12, padding: 12, textAlign: "center" }}>
