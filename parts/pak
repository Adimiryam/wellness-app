          <div style={{ background: "#faf5ff", borderRadius: 12, padding: 12, textAlign: "center" }}>
            <div style={{ fontSize: 11, color: "#64748b" }}>ירידה שבועית ממוצעת</div>
            <div style={{ fontSize: 18, fontWeight: 700, color: "#7c3aed" }}>{Math.abs(weeklyRate).toFixed(2)} ק"ג</div>
