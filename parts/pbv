
        {/* ===== MORNING QUESTIONNAIRE ===== */}
        <div style={{ background: "#fff", borderRadius: 16, padding: 20, marginBottom: 16, boxShadow: "0 2px 8px rgba(0,0,0,0.06)", border: morningDone ? "2px solid #86efac" : "2px solid #fbbf24" }}>
          <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: morningDone ? 0 : 16 }}>
            {morningDone && <button onClick={() => setMorningDone(false)} style={{ background: "none", border: "none", color: "#6366f1", cursor: "pointer", fontSize: 13 }}>ערוך</button>}
            <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
              <span style={{ fontSize: 16, fontWeight: 700, color: "#1e293b" }}>שאלון בוקר</span>
              <span>☀️</span>
            </div>
          </div>

          {morningDone ? (
            <div style={{ display: "flex", alignItems: "center", gap: 8, marginTop: 8 }}>
              <Check size={16} color="#22c55e" />
              <span style={{ fontSize: 13, color: "#166534" }}>הושלם — {sleepHours} שעות שינה, מצב רוח {morningMood}/5, אנרגיה {wokeUpFeeling}/5</span>
            </div>
          ) : (
            <div>
              <div style={{ marginBottom: 16 }}>
                <label style={{ display: "block", fontSize: 14, fontWeight: 600, color: "#475569", marginBottom: 8, textAlign: "right" }}>כמה שעות ישנת הלילה?</label>
                <div style={{ display: "flex", alignItems: "center", gap: 12, justifyContent: "flex-end" }}>
                  <span style={{ fontSize: 22, fontWeight: 700, color: "#6366f1" }}>{sleepHours} שעות</span>
                  <input type="range" min="2" max="14" step="0.5" value={sleepHours} onChange={e => setSleepHours(parseFloat(e.target.value))} style={{ width: "60%", accentColor: "#6366f1" }} />
                </div>
              </div>
              <RatingInput value={sleepQuality} onChange={setSleepQuality} label="איכות השינה (1=גרועה, 5=מעולה)" icon={BedDouble} color="#6366f1" />
              <div style={{ marginBottom: 16 }}>
                <label style={{ display: "block", fontSize: 14, fontWeight: 600, color: "#475569", marginBottom: 8, textAlign: "right" }}>חלומות?</label>
                <div style={{ display: "flex", gap: 8, justifyContent: "flex-end" }}>
                  {[{ id: "none", label: "בלי" }, { id: "good", label: "טובים" }, { id: "neutral", label: "רגיל" }, { id: "bad", label: "רעים" }, { id: "vivid", label: "חיים מאוד" }].map(d => (
                    <button key={d.id} onClick={() => setDreamsQuality(d.id)} style={{ padding: "8px 14px", borderRadius: 20, border: "2px solid", borderColor: dreamsQuality === d.id ? "#6366f1" : "#e2e8f0", background: dreamsQuality === d.id ? "#eef2ff" : "#fff", color: dreamsQuality === d.id ? "#6366f1" : "#64748b", cursor: "pointer", fontSize: 13, fontWeight: 500 }}>{d.label}</button>
                  ))
                </div>
              </div>
              <RatingInput value={wokeUpFeeling} onChange={setWokeUpFeeling} label="איך קמת? (1=עייף, 5=עירני)" icon={Sun} color="#f59e0b" />
              <RatingInput value={morningMood} onChange={setMorningMood} label="מצב רוח בבוקר" icon={Smile} color="#ec4899" />
              <RatingInput value={morningHunger} onChange={setMorningHunger} label="רמת רעב (1=בכלל לא, 5=רעב מאוד)" icon={UtensilsCrossed} color="#ef4444" />
              <RatingInput value={morningStress} onChange={setMorningStress} label="רמת מתח/לחץ" icon={Brain} color="#8b5cf6" />
              {userProfile?.trackingChoices?.includes("weight") && (
                <div style={{ marginBottom: 16 }}>
                  <label style={{ display: "block", fontSize: 14, fontWeight: 600, color: "#475569", marginBottom: 8, textAlign: "right" }}>⚖️ משקל בוקר (ק״ג)</label>
                  <input type="number" placeholder="למשל: 67.5" value={morningWeight} onChange={e => setMorningWeight(e.target.value)} step="0.1" style={{ width: "100%", padding: 12, borderRadius: 10, border: "2px solid #e2e8f0", fontSize: 15, textAlign: "right", boxSizing: "border-box" }} />
                </div>
              )}
              <div style={{ display: "flex", flexWrap: "wrap", gap: 10, marginBottom: 16 }}>
                <label style={{ display: "flex", alignItems: "center", gap: 8, cursor: "pointer", fontSize: 14, fontWeight: 600, color: "#475569" }}>
                  <input type="checkbox" checked={morningBloated} onChange={() => setMorningBloated(!morningBloated)} style={{ width: 18, height: 18, accentColor: "#6366f1" }} />
                  🫧 נפיחות?
                </label>
              </div>
              <div style={{ marginBottom: 16 }}>
                <label style={{ display: "block", fontSize: 14, fontWeight: 600, color: "#475569", marginBottom: 8, textAlign: "right" }}>🚽 שירותים בבוקר?</label>
                <div style={{ display: "flex", gap: 8, justifyContent: "flex-end" }}>
                  {[{ id: "yes", label: "כן, תקין" }, { id: "constipated", label: "עצירות" }, { id: "diarrhea", label: "שלשול" }, { id: "no", label: "לא" }].map(b => (
                    <button key={b.id} onClick={() => setWentToBathroom(b.id)} style={{ padding: "8px 12px", borderRadius: 20, border: "2px solid", borderColor: wentToBathroom === b.id ? "#6366f1" : "#e2e8f0", background: wentToBathroom === b.id ? "#eef2ff" : "#fff", color: wentToBathroom === b.id ? "#6366f1" : "#64748b", cursor: "pointer", fontSize: 12, fontWeight: 500 }}>{b.label}</button>
