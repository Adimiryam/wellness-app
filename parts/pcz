          <>
            {/* Period selector */}
            <div style={{ display: "flex", gap: 6, marginBottom: 14, flexWrap: "wrap", justifyContent: "center" }}>
              {[{ id: "week", label: "שבוע" }, { id: "month", label: "חודש" }, { id: "3months", label: "3 חודשים" }, { id: "all", label: "הכל" }].map(p => (
                <button key={p.id} onClick={() => setDiaryTrendPeriod(p.id)} style={{
                  padding: "6px 12px", borderRadius: 20, border: "none", fontSize: 12, fontWeight: 600, cursor: "pointer",
                  background: diaryTrendPeriod === p.id ? "#f59e0b" : "#f1f5f9",
