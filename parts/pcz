                      {mealFoods.map((f, i) => (
                        <div key={i} style={{ display: "flex", justifyContent: "space-between", alignItems: "center", padding: "6px 0", borderBottom: i < mealFoods.length - 1 ? "1px solid #f1f5f9" : "none" }}>
