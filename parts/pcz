              ))}
            </div>

            {/* Average Stats */}
            <div style={{ background: "linear-gradient(135deg, #f59e0b, #f97316)", borderRadius: 16, padding: 16, marginBottom: 14, color: "#fff", textAlign: "center" }}>
              <div style={{ fontSize: 13, opacity: 0.85 }}>ממוצע קלוריות יומי ({trendData.length} ימים)</div>
              <div style={{ fontSize: 36, fontWeight: 800 }}>{avgCalories}</div>
              <div style={{ display: "flex", justifyContent: "center", gap: 20, marginTop: 8 }}>
