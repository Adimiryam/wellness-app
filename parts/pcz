                <div><div style={{ fontSize: 11, opacity: 0.8 }}>פחמימות</div><div style={{ fontSize: 16, fontWeight: 700 }}>{avgCarbs}g</div></div>
                <div><div style={{ fontSize: 11, opacity: 0.8 }}>שומן</div><div style={{ fontSize: 16, fontWeight: 700 }}>{avgFat}g</div></div>
              </div>
            </div>

            {/* Calorie Trend Graph */}
            <div style={{ background: "#fff", borderRadius: 16, padding: 14, marginBottom: 14, boxShadow: "0 1px 4px rgba(0,0,0,0.06)" }}>
              <div style={{ fontSize: 14, fontWeight: 600, color: "#374151", marginBottom: 8, textAlign: "right" }}>
