const PillToggle = ({ items, selected, onToggle, multi = true }) => (
  <div style={{ display: "flex", flexWrap: "wrap", gap: 8, justifyContent: "flex-end" }}>
    {items.map(item => {
      const isSelected = multi ? selected.includes(item.id) : selected === item.id;
      return (
        <button key={item.id} onClick={() => onToggle(item.id)}
          style={{
            padding: "8px 14px", borderRadius: 20, border: "2px solid",
            borderColor: isSelected ? (item.color || "#6366f1") : "#e2e8f0",
            background: isSelected ? `${item.color || "#6366f1"}15` : "#fff",
            color: isSelected ? (item.color || "#6366f1") : "#64748b",
            cursor: "pointer", fontSize: 14, fontWeight: 500,
            display: "flex", alignItems: "center", gap: 6, transition: "all 0.2s"
          }}>
          <span>{item.label}</span>
          {item.icon && typeof item.icon === "string" && <span>{item.icon}</span>}
        </button>
      );
    })}
  </div>
);

const ProgressBar = ({ value, max, color, label, unit = "" }) => {
  const pct = Math.min((value / max) * 100, 100);
  return (
    <div style={{ marginBottom: 12 }}>
      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 4, fontSize: 13 }}>
        <span style={{ color: "#64748b" }}>{Math.round(value)}{unit} / {max}{unit}</span>
        <span style={{ fontWeight: 600, color: "#1e293b" }}>{label}</span>
      </div>
      <div style={{ height: 8, borderRadius: 4, background: "#f1f5f9", overflow: "hidden" }}>
        <div style={{ height: "100%", width: `${pct}%`, borderRadius: 4, background: color, transition: "width 0.5s" }} />
      </div>
    </div>
  );
};

const BmiCard = ({ profile, morningWeight }) => {
  if (!profile?.height || (!profile?.currentWeight && !morningWeight)) return null;
  const h = parseFloat(profile.height) / 100;
  const w = parseFloat(morningWeight || profile.currentWeight);
  if (!h || !w || h <= 0) return null;
  const bmiVal = w / (h * h);
  const bmi = bmiVal.toFixed(1);
  const info = bmiVal < 18.5 ? { label: "תת משקל", color: "#3b82f6", bg: "#eff6ff", emoji: "⚠️" }
    : bmiVal < 25 ? { label: "משקל תקין", color: "#22c55e", bg: "#f0fdf4", emoji: "✅" }
    : bmiVal < 30 ? { label: "עודף משקל", color: "#f59e0b", bg: "#fffbeb", emoji: "⚡" }
    : { label: "השמנה", color: "#ef4444", bg: "#fef2f2", emoji: "⚠️" };
  const pct = Math.min(100, Math.max(0, ((bmiVal - 15) / 25) * 100));
  return (
    <div style={{ background: info.bg, borderRadius: 16, padding: 16, marginBottom: 16, border: "2px solid " + info.color + "22", direction: "rtl" }}>
      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 8 }}>
        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
          <span style={{ fontSize: 13, fontWeight: 700, color: info.color }}>{info.emoji} {info.label}</span>
        </div>
        <div style={{ fontSize: 14, fontWeight: 700, color: "#1e293b" }}>BMI מדד</div>
      </div>
      <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 8 }}>
